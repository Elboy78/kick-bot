# ─────────────────────────────────────────
#  Configuration du bot Kick — copiez ce
#  fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────

# Nom de votre chaîne Kick (sans le @)
KICK_CHANNEL=votre_chaine

# ID numérique de votre chaîne (trouvable via l'API Kick)
KICK_CHANNEL_ID=123456

# Email et mot de passe du compte bot (pour node refresh-token.js)
BOT_EMAIL=email_du_compte_bot@gmail.com
BOT_PASSWORD=mot_de_passe_du_compte_bot

# Token Kick — généré automatiquement par: node refresh-token.js
# Renouvelez-le quand le bot dit "Token expiré"
KICK_TOKEN=

# Nom du bot dans le chat (votre compte connecté)
BOT_USERNAME=votre_bot_username

# Points gagnés toutes les 5 minutes de visionnage
POINTS_PER_INTERVAL=10

# Intervalle en millisecondes (300000 = 5 minutes)
POINTS_INTERVAL_MS=300000

# Port du panel web
PANEL_PORT=3000

# Clé secrète pour l'API du panel (changez-la !)
PANEL_SECRET=changez_cette_cle_secrete

# Mot de passe partagé pour accéder au panel (requis pour se connecter)
PANEL_PASSWORD=mot_de_passe_panel

# ─────────────────────────────────────────
#  TTS Donations (optionnel)
# ─────────────────────────────────────────

# Clé API ElevenLabs — laisser vide pour désactiver la synthèse vocale
# (le message s'affichera quand même sur l'overlay sans son)
ELEVENLABS_API_KEY=

# ID de la voix ElevenLabs à utiliser
ELEVENLABS_VOICE_ID=

# Montant minimum (en €) pour déclencher le TTS — 0 = tous les dons
TTS_MIN_DONATION=1

# Longueur maximale du message lu (caractères)
TTS_MAX_TEXT_LENGTH=180

# Secret optionnel à vérifier dans le header x-webhook-secret du webhook de dons
TTS_WEBHOOK_SECRET=
