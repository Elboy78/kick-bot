# ─────────────────────────────────────────
#  Configuration du bot Kick — copiez ce
#  fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────

# Nom de votre chaîne Kick (sans le @)
KICK_CHANNEL=fack7up

# ID numérique de votre chaîne (trouvable via l'API Kick)
KICK_CHANNEL_ID=596440

# Token d'authentification Kick (OAuth ou session token)
# Obtenez-le en vous connectant à kick.com → F12 → Application → Cookies → kick_session
KICK_%3D

# Nom du bot dans le chat (votre compte connecté)
BOT_USERNAME=FackBotos

# Points gagnés toutes les 5 minutes de visionnage
POINTS_PER_INTERVAL=10

# Intervalle en millisecondes (300000 = 5 minutes)
POINTS_INTERVAL_MS=300000

# Port du panel web
PANEL_PORT=3000

# Clé secrète pour l'API du panel (changez-la !)
PANEL_SECRET=FackKeysBot

# Connexion à kick du bot
BOT_EMAIL=alphaelboy@gmail.com
BOT_PASSWORD=Fack7Keys@Bot